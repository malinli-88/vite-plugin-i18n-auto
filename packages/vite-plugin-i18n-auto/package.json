{
  "name": "vite-plugin-i18n-auto",
  "version": "0.1.0",
  "description": "Vite 插件聚合：中文提取 + React 运行时 i18n（单包配置）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["vite", "plugin", "i18n", "react", "internationalization", "chinese"],
  "license": "MIT",
  "dependencies": {
    "@vite-plugin-i18n-auto/core": "^0.1.0",
    "@vite-plugin-i18n-auto/extract": "^0.1.0",
    "@vite-plugin-i18n-auto/runtime": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
