{
  "name": "@vite-plugin-i18n-auto/overall",
  "version": "0.1.1",
  "description": "Vite 插件聚合：中文提取 + React 运行时 i18n（单包配置）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "i18n-extract": "./bin/i18n-extract.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./virtual-i18n-runtime": "./virtual-i18n-runtime.d.ts"
  },
  "files": ["dist", "bin", "virtual-i18n-runtime.d.ts"],
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["vite", "plugin", "i18n", "react", "internationalization", "chinese"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/malinli-88/vite-plugin-i18n-auto.git",
    "directory": "packages/vite-plugin-i18n-auto"
  },
  "bugs": {
    "url": "https://github.com/malinli-88/vite-plugin-i18n-auto/issues"
  },
  "homepage": "https://github.com/malinli-88/vite-plugin-i18n-auto/tree/main/packages/vite-plugin-i18n-auto#readme",
  "dependencies": {
    "@vite-plugin-i18n-auto/core": "^0.1.1",
    "@vite-plugin-i18n-auto/extract": "^0.1.1",
    "@vite-plugin-i18n-auto/runtime": "^0.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
